PUBLIC_BASE_URL=https://baupass-production.up.railway.app
SUPPIX_PG_RUNTIME=0
SUPPIX_DB_PATH=/data/baupass.db
SUPPIX_SQLITE_JOURNAL_MODE=DELETE
SUPPIX_BACKUP_ON_BOOT=1
SUPPIX_BACKUP_RETENTION_DAYS=30
SUPPIX_SECRET_KEY=REPLACE_64_CHAR_RANDOM_HEX
SUPPIX_AUDIT_SIGNING_KEY=REPLACE_64_CHAR_RANDOM_HEX
SUPPIX_ALLOW_DEMO=0
SUPPIX_ENABLE_HSTS=1
SUPPIX_IMMUTABLE_AUDIT=1
SUPPIX_REQUIRE_SUPERADMIN_2FA=0
SUPPIX_LOGIN_RATE_MAX=120
SUPPIX_LOGIN_MAX_ATTEMPTS=12
SUPPIX_LOGIN_LOCK_MINUTES=10
SUPPIX_PLATFORM_DISPLAY_NAME=WorkPass
SUPPIX_OPERATOR_DISPLAY_NAME=Suppix AI
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USERNAME=suppix-workpass-ai@outlook.de
SMTP_PASSWORD=REPLACE_OUTLOOK_APP_PASSWORD
SMTP_SENDER_EMAIL=suppix-workpass-ai@outlook.de
