{
  "name": "workpass-e2e",
  "private": true,
  "version": "1.0.0",
  "description": "WorkPass test and desktop shell",
  "main": "desktop/main.js",
  "scripts": {
    "desktop": "electron desktop/main.js",
    "desktop:local": "cross-env WORKPASS_DESKTOP_URL=http://127.0.0.1:8080 electron desktop/main.js",
    "build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64",
    "test:e2e": "playwright test",
    "test:e2e:platform": "playwright test tests/e2e/platform-smoke.spec.js",
    "test:e2e:preview": "playwright test tests/e2e/preview-session.spec.js",
    "test:e2e:ops": "playwright test tests/e2e/invoice-ops.spec.js",
    "test:e2e:all": "playwright test tests/e2e/preview-session.spec.js tests/e2e/invoice-ops.spec.js",
    "vendor:signotec": "node scripts/sync-signotec-vendor.js",
    "vendor:signotec:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-signotec-lib.ps1",
    "vendor:signotec:get": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/get-signotec-lib.ps1 -AfterInstall"
  },
  "build": {
    "appId": "com.suppix.workpass",
    "productName": "WorkPass",
    "directories": {
      "output": "dist"
    },
    "files": [
      "desktop/**",
      "index.html",
      "app.js",
      "styles.css",
      "workpass-storage.js",
      "control-manifest.json",
      "control-sw.js",
      "branding/suppix-icon-192.png",
      "branding/suppix-icon-512.png",
      "branding/suppix-icon-512.ico",
      "branding/suppix-ai-mark.svg",
      "branding/suppix-ai-logo.svg"
    ],
    "win": {
      "target": [{"target": "portable"}],
      "icon": "branding/suppix-icon-512.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8"
  }
}
