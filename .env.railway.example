# Railway service variables (copy into Railway → Variables)

PUBLIC_BASE_URL=https://your-service.up.railway.app
BAUPASS_DB_PATH=/data/baupass.db
BAUPASS_SECRET_KEY=change-me-long-random
BAUPASS_AUDIT_SIGNING_KEY=change-me-another-long-random

# SMTP (Brevo / Gmail)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=noreply@your-domain.de
SMTP_SENDER_NAME=BauPass

# Security
BAUPASS_ENABLE_HSTS=1
# Erst auf 1 setzen, wenn Superadmin E-Mail + OTP getestet wurde
BAUPASS_REQUIRE_SUPERADMIN_2FA=0
BAUPASS_IMMUTABLE_AUDIT=1
BAUPASS_LOGIN_RATE_MAX=120
BAUPASS_BACKUP_RETENTION_DAYS=30

# Optional Redis (rate limits + background jobs)
REDIS_URL=redis://default:password@redis.railway.internal:6379
BAUPASS_DAILY_JOBS_MODE=auto

# Web Push (worker PWA)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
