# Railway service variables (copy into Railway → Variables)
# Canonical prefix: SUPPIX_*  — legacy BAUPASS_* is still mirrored at startup for old deploys.

PUBLIC_BASE_URL=https://your-service.up.railway.app
# Login funktioniert nur mit vollständiger DB. Schnellstart mit SQLite auf Volume:
SUPPIX_PG_RUNTIME=0
# Pflicht für dauerhafte Daten (Mitarbeiter, Karten, Anträge) – Volume muss auf /data gemountet sein
SUPPIX_DB_PATH=/data/baupass.db
# Railway volumes: WAL verursacht oft "disk I/O error" — DELETE ist stabiler (wird auf /data auto-erkannt)
SUPPIX_SQLITE_JOURNAL_MODE=DELETE
# Automatisches Backup beim Start (nur wenn persistent + Mitarbeiter vorhanden)
SUPPIX_BACKUP_ON_BOOT=1
SUPPIX_SECRET_KEY=change-me-long-random
SUPPIX_AUDIT_SIGNING_KEY=change-me-another-long-random

# SMTP (Outlook — App-Passwort unter https://account.microsoft.com/security)
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USERNAME=suppix-workpass-ai@outlook.de
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=suppix-workpass-ai@outlook.de
SMTP_SENDER_NAME=WorkPass
SUPPIX_CONTACT_EMAIL=suppix-workpass-ai@outlook.de
SUPPIX_FOUNDER_EMAIL=suppix-workpass-ai@outlook.de

# Security
SUPPIX_ENABLE_HSTS=1
# Erst auf 1 setzen, wenn Superadmin E-Mail + OTP getestet wurde
SUPPIX_REQUIRE_SUPERADMIN_2FA=0
SUPPIX_IMMUTABLE_AUDIT=1
SUPPIX_LOGIN_RATE_MAX=120
SUPPIX_LOGIN_MAX_ATTEMPTS=12
SUPPIX_LOGIN_LOCK_MINUTES=10
# KI-Assistent (Enterprise-Tarif) — WICHTIG: Key und Modell getrennt!
# OPENAI_API_KEY = sk-proj-...  (nur hier, niemals als Modellname)
OPENAI_API_KEY=
# Optional Modell (Standard: gpt-4o-mini). NICHT den API-Key hier eintragen!
# SUPPIX_AI_MODEL=gpt-4o-mini
# Optional Azure OpenAI statt OpenAI:
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# Whisper auf Azure (Deployment-Name in Azure AI Studio, z. B. whisper):
# AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper
# Tool-Calling Agenten (11 Live-DB-Tools, 5 Spezial-Agenten)
SUPPIX_AI_TOOLS=1
# SUPPIX_AI_MAX_TOOL_ROUNDS=6
# Slack/Teams Tagesbriefing (optional)
# SUPPIX_AI_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SUPPIX_AI_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# SUPPIX_AI_WEBHOOK_URL=
# Worker Voice (Whisper): OPENAI_API_KEY oder Azure (siehe AZURE_OPENAI_WHISPER_DEPLOYMENT)
# TTS — OpenAI (Standard, nutzt OPENAI_API_KEY) mit Personas Ghizlane/Ramona/Vanessa:
# SUPPIX_TTS_PROVIDER=openai
# SUPPIX_TTS_MODEL=gpt-4o-mini-tts
# Optional ElevenLabs (exakte Stimmen): SUPPIX_TTS_PROVIDER=elevenlabs + ELEVENLABS_API_KEY
# KI — Gründer-Profil (Antwort auf „Wer hat das System gegründet?“):
# SUPPIX_FOUNDER_NAME=Sherif Mohamed
# SUPPIX_FOUNDER_TITLE=Gründer & Geschäftsführer
# SUPPIX_FOUNDER_COMPANY=Suppix Technologie UG
# SUPPIX_FOUNDER_BIO=Kurze Biografie in einer Zeile
# SUPPIX_FOUNDER_EMAIL=suppix-workpass-ai@outlook.de
# Tagesbriefing Cron (Enterprise, Slack/Teams oder E-Mail)
# SUPPIX_AI_BRIEFING_CRON=1
# SUPPIX_AI_BRIEFING_HOUR=7
# SUPPIX_AI_BRIEFING_TZ=Europe/Berlin
# SUPPIX_AI_BRIEFING_LANG=de
# SUPPIX_AI_BRIEFING_EMAIL=ops@firma.de
SUPPIX_BACKUP_RETENTION_DAYS=30

# ── Redis (strongly recommended for global production) ───────────────────────
# Railway: New → Database → Redis → on API service Variables → Add Reference → REDIS_URL
# Do NOT paste redis.railway.internal manually — use Railway's reference variable.
# REDIS_URL=${{Redis.REDIS_URL}}
# Second service start command: python -m backend.app.tasks.worker
SUPPIX_DAILY_JOBS_MODE=rq
SUPPIX_INVOICE_RETRY_MODE=rq
SUPPIX_DUNNING_MODE=rq
SUPPIX_WORKER_SESSION_CLEANUP_MODE=rq
# Second Railway service start command: python -m backend.app.tasks.worker

# Worker Hybrid App (Flutter) — see .env.worker-mobile.example for full list
SUPPIX_WORKER_DEVICE_BINDING=1
SUPPIX_WORKER_JWT=1
SUPPIX_WORKER_JWT_SECRET=change-me-worker-jwt-32-chars-minimum
# SUPPIX_WORKER_APK_URL=https://your-cdn.example/app-release.apk
# SUPPIX_TESTFLIGHT_URL=https://testflight.apple.com/join/XXXXXXXX
# SUPPIX_PLAY_STORE_URL=
# SUPPIX_APP_STORE_URL=
# Checklist: GET /api/worker-app/mobile-setup

# ── PostgreSQL (phase 2 — ONLY after sqlite_to_postgres.py + full schema) ─
# Do NOT set SUPPIX_PG_RUNTIME=1 until migration completed or the app may fail boot jobs.
# For Railway with /data volume, prefer SQLite (default):
#   SUPPIX_DB_PATH=/data/baupass.db
# DATABASE_URL=postgresql://user:pass@host:5432/railway
# SUPPIX_PG_RUNTIME=1
# SUPPIX_PG_REQUIRED=0
# SUPPIX_PG_AUTO_BOOTSTRAP=1
# SUPPIX_PG_BOOTSTRAP_SQLITE_PATH=/data/baupass.db
# SUPPIX_ALLOW_SQLITE_PRODUCTION=1
# DB_POOL_MIN_SIZE=2
# DB_POOL_MAX_SIZE=20
# DATABASE_READ_REPLICA_URL=
# DB_READ_POOL_MIN_SIZE=2
# DB_READ_POOL_MAX_SIZE=16
# SUPPIX_DR_MAX_BACKUP_AGE_HOURS=48
# SUPPIX_DR_REQUIRE_REPLICA=0
# SUPPIX_ARCHIVE_ACCESS_LOGS_ON_BOOT=0
# SUPPIX_ACCESS_LOG_RETENTION_DAYS=365
# Waitress (Railway default) does not support WebSocket upgrades — leave disabled.
# SUPPIX_WEBSOCKET_ENABLED=0
# SUPPIX_WEBSOCKET_REQUIRE_SESSION=1
# SUPPIX_ZERO_TRUST_DEVICE_BINDING=0
# SUPPIX_FIELD_ENCRYPTION_KEY=
# SUPPIX_PG_DR_SNAPSHOT_ON_BOOT=0
# SUPPIX_SAP_BASE_URL=
# SUPPIX_ORACLE_BASE_URL=
# SUPPIX_SCHEDULE_ACCESS_ARCHIVE=0
# SUPPIX_ZERO_TRUST_IP_ALLOWLIST=
# SUPPIX_ENFORCE_DATA_RESIDENCY=0

# ── Observability (optional) ─────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SUPPIX_OTEL=0
# SUPPIX_LOG_FORWARD_URL=
# SUPPIX_LOG_FORWARD_TOKEN=

# ── Global cloud / edge (optional) ────────────────────────────────────────
# SUPPIX_DEFAULT_TIMEZONE=UTC
# SUPPIX_REGION=eu-west
# SUPPIX_REGION_STRATEGY=single
# SUPPIX_ACTIVE_REGIONS=eu-west,eu-central
# SUPPIX_CDN_CACHE_SECONDS=86400
# SUPPIX_PWA_SHELL_CACHE_SECONDS=300
# SUPPIX_REQUIRE_REDIS=0
# SUPPIX_PLATFORM_ENABLED=1

# ── Platform (optional) ───────────────────────────────────────────────────
# OPENAI_API_KEY=
# SUPPIX_AI_MODEL=gpt-4o-mini
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PROFESSIONAL=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# STRIPE_PRICE_STARTER_ANNUAL=price_...
# STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...
# STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...
# STRIPE_PRICE_PROFESSIONAL_WORKER=price_...
# STRIPE_PRICE_ENTERPRISE_WORKER=price_...
# SUPPIX_STRIPE_TRIAL_DAYS=14
# Webhooks: STRIPE_WEBHOOK_SECRET required when Stripe is configured (dev: SUPPIX_ALLOW_UNSIGNED_STRIPE_WEBHOOKS=1)
# SUPPIX_ZERO_TRUST=0
# SUPPIX_SEED_DEMO_ENTERPRISE=1
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# ── Worker Hybrid App (Flutter) — primary push channel ───────────────────────
# Option A (legacy): Firebase Console → Cloud Messaging → Server key
FCM_SERVER_KEY=
# Option B (recommended): FCM HTTP v1 service account JSON (one line or base64)
# FCM_PROJECT_ID=baupass-worker
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FCM_SERVICE_ACCOUNT_B64=
# FCM_V1_ONLY=1
# Enterprise: demo seed disabled on Railway unless explicitly enabled
# SUPPIX_ALLOW_DEMO=0
# SUPPIX_CONTACT_EMAIL=suppix-workpass-ai@outlook.de
# SUPPIX_OPS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SUPPIX_OPS_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# Platform Guardian (Phase A): polls health every 60s, alerts on degraded/down.
# SUPPIX_GUARDIAN_ENABLED=1
# SUPPIX_GUARDIAN_INTERVAL_SECONDS=60
# SUPPIX_GUARDIAN_ALERT_COOLDOWN_SECONDS=900
# SUPPIX_GUARDIAN_NOTIFY_RECOVERY=1
# SUPPIX_GUARDIAN_WEBHOOK_URL=
# SUPPIX_GUARDIAN_TEAMS_WEBHOOK_URL=
# SUPPIX_GUARDIAN_WEBHOOK_URLS=
# Phase B — safe auto-remediation (sessions, retries, stale alerts)
# SUPPIX_GUARDIAN_REMEDIATION=1
# SUPPIX_GUARDIAN_REMEDIATION_COOLDOWN_SECONDS=300
# Phase C — login spike detection and security alerts
# SUPPIX_GUARDIAN_SECURITY=1
# SUPPIX_GUARDIAN_SECURITY_REMEDIATION=1
# SUPPIX_GUARDIAN_LOGIN_SPIKE_THRESHOLD=15
# SUPPIX_GUARDIAN_LOGIN_DAILY_THRESHOLD=50
# SUPPIX_GUARDIAN_SECURITY_ALERT_COOLDOWN_SECONDS=600
# SUPPIX_GUARDIAN_IP_BAN_THRESHOLD=8
# SUPPIX_GUARDIAN_IP_BAN_HOURS=2
# KI (required for Suppix AI assistant responses):
# OPENAI_API_KEY=sk-...
# GitHub secret FIREBASE_GOOGLE_SERVICES_JSON for mobile-release workflow
# Go-live validation: python backend/ops/validate_enterprise_env.py --base-url $PUBLIC_BASE_URL
# Docs: docs/enterprise-go-live-AR.md
# After GitHub Actions "Build worker APK" → Artifacts → host APK and set:
# SUPPIX_WORKER_APK_URL=https://your-cdn.example/baupass-worker.apk
# Daily cron (with SUPPIX_DAILY_JOBS_MODE=rq) sends FCM for documents expiring within 14 days.

# ── Kameras / RTSP-Bridge (Baustelle — ohne Code-Änderung) ───────────────────
# Geheimer Token für lokalen Agent auf der Baustelle (scripts/rtsp_camera_agent.py)
SUPPIX_RTSP_BRIDGE_TOKEN=change-me-long-random-rtsp-token
# Offline-Prüfung alle N Sekunden (Hintergrund-Thread, kein Worker nötig)
SUPPIX_CAMERA_HEALTH_SECONDS=120
# Kamera gilt als online wenn Heartbeat jünger als N Sekunden
SUPPIX_CAMERA_ONLINE_THRESHOLD_SECONDS=180
# Nachtbericht (PDF per E-Mail) im täglichen Job
SUPPIX_CAMERA_NIGHTLY_DIGEST=1
SUPPIX_CAMERA_DIGEST_HOURS=12
# Optional: Azure Face für Gesichtsabgleich auf Snapshots
# SUPPIX_AZURE_FACE_ENDPOINT=https://YOUR.cognitiveservices.azure.com
# SUPPIX_AZURE_FACE_KEY=
# SUPPIX_AZURE_FACE_MIN_CONFIDENCE=0.5
# Docs: docs/camera-rtsp-bridge-DE.md | Handover: docs/HANDOVER-PLATFORM-AR.md

# Legacy Web Push (browser PWA only — not used by Flutter hybrid app)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:admin@example.com

# Signotec signature pad — STPadServerLib.js on server (see vendor/signotec/README.md)
# Prefer: copy file to vendor/signotec/ via  npm run vendor:signotec  or  .\scripts\install-signotec-lib.ps1
# Fallback for tiny builds only (file usually too large for env var):
# SUPPIX_SIGNOTEC_LIB_BASE64=
