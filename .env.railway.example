# Railway service variables (copy into Railway → Variables)

PUBLIC_BASE_URL=https://your-service.up.railway.app
# Login funktioniert nur mit vollständiger DB. Schnellstart mit SQLite auf Volume:
BAUPASS_PG_RUNTIME=0
# Pflicht für dauerhafte Daten (Mitarbeiter, Karten, Anträge) – Volume muss auf /data gemountet sein
BAUPASS_DB_PATH=/data/baupass.db
# Railway volumes: WAL verursacht oft "disk I/O error" — DELETE ist stabiler (wird auf /data auto-erkannt)
BAUPASS_SQLITE_JOURNAL_MODE=DELETE
# Automatisches Backup beim Start (nur wenn persistent + Mitarbeiter vorhanden)
BAUPASS_BACKUP_ON_BOOT=1
BAUPASS_SECRET_KEY=change-me-long-random
BAUPASS_AUDIT_SIGNING_KEY=change-me-another-long-random

# SMTP (Brevo / Gmail)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=noreply@your-domain.de
SMTP_SENDER_NAME=BauPass

# Security
BAUPASS_ENABLE_HSTS=1
# Erst auf 1 setzen, wenn Superadmin E-Mail + OTP getestet wurde
BAUPASS_REQUIRE_SUPERADMIN_2FA=0
BAUPASS_IMMUTABLE_AUDIT=1
BAUPASS_LOGIN_RATE_MAX=120
BAUPASS_LOGIN_MAX_ATTEMPTS=12
BAUPASS_LOGIN_LOCK_MINUTES=10
# KI-Assistent (Enterprise-Tarif) — WICHTIG: Key und Modell getrennt!
# OPENAI_API_KEY = sk-proj-...  (nur hier, niemals als Modellname)
OPENAI_API_KEY=
# Optional Modell (Standard: gpt-4o-mini). NICHT den API-Key hier eintragen!
# BAUPASS_AI_MODEL=gpt-4o-mini
# Optional Azure OpenAI statt OpenAI:
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# Whisper auf Azure (Deployment-Name in Azure AI Studio, z. B. whisper):
# AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper
# Tool-Calling Agenten (11 Live-DB-Tools, 5 Spezial-Agenten)
BAUPASS_AI_TOOLS=1
# BAUPASS_AI_MAX_TOOL_ROUNDS=6
# Slack/Teams Tagesbriefing (optional)
# BAUPASS_AI_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# BAUPASS_AI_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# BAUPASS_AI_WEBHOOK_URL=
# Worker Voice (Whisper): OPENAI_API_KEY oder Azure (siehe AZURE_OPENAI_WHISPER_DEPLOYMENT)
# TTS — OpenAI (Standard, nutzt OPENAI_API_KEY) mit Personas Ghizlane/Ramona/Vanessa:
# BAUPASS_TTS_PROVIDER=openai
# BAUPASS_TTS_MODEL=gpt-4o-mini-tts
# Optional ElevenLabs (exakte Stimmen): BAUPASS_TTS_PROVIDER=elevenlabs + ELEVENLABS_API_KEY
# KI — Gründer-Profil (Antwort auf „Wer hat das System gegründet?“):
# BAUPASS_FOUNDER_NAME=Sherif Mohamed
# BAUPASS_FOUNDER_TITLE=Gründer & Geschäftsführer
# BAUPASS_FOUNDER_COMPANY=Baukometra
# BAUPASS_FOUNDER_BIO=Kurze Biografie in einer Zeile
# BAUPASS_FOUNDER_EMAIL=baupass-control@outlook.de
# Tagesbriefing Cron (Enterprise, Slack/Teams oder E-Mail)
# BAUPASS_AI_BRIEFING_CRON=1
# BAUPASS_AI_BRIEFING_HOUR=7
# BAUPASS_AI_BRIEFING_TZ=Europe/Berlin
# BAUPASS_AI_BRIEFING_LANG=de
# BAUPASS_AI_BRIEFING_EMAIL=ops@firma.de
BAUPASS_BACKUP_RETENTION_DAYS=30

# ── Redis (strongly recommended for global production) ───────────────────────
# Railway: New → Database → Redis → Reference REDIS_URL on API + Worker
REDIS_URL=redis://default:password@redis.railway.internal:6379
# Second service start command: python -m backend.app.tasks.worker
BAUPASS_DAILY_JOBS_MODE=rq
BAUPASS_INVOICE_RETRY_MODE=rq
BAUPASS_DUNNING_MODE=rq
BAUPASS_WORKER_SESSION_CLEANUP_MODE=rq
# Second Railway service start command: python -m backend.app.tasks.worker

# Worker Hybrid App (Flutter) — see .env.worker-mobile.example for full list
BAUPASS_WORKER_DEVICE_BINDING=1
BAUPASS_WORKER_JWT=1
BAUPASS_WORKER_JWT_SECRET=change-me-worker-jwt-32-chars-minimum
# BAUPASS_WORKER_APK_URL=https://your-cdn.example/app-release.apk
# BAUPASS_TESTFLIGHT_URL=https://testflight.apple.com/join/XXXXXXXX
# BAUPASS_PLAY_STORE_URL=
# BAUPASS_APP_STORE_URL=
# Checklist: GET /api/worker-app/mobile-setup

# ── PostgreSQL (phase 2 — ONLY after sqlite_to_postgres.py + full schema) ─
# Do NOT set BAUPASS_PG_RUNTIME=1 until migration completed or the app may fail boot jobs.
# For Railway with /data volume, prefer SQLite (default):
#   BAUPASS_DB_PATH=/data/baupass.db
# DATABASE_URL=postgresql://user:pass@host:5432/railway
# BAUPASS_PG_RUNTIME=1
# BAUPASS_PG_REQUIRED=0
# BAUPASS_PG_AUTO_BOOTSTRAP=1
# BAUPASS_PG_BOOTSTRAP_SQLITE_PATH=/data/baupass.db
# BAUPASS_ALLOW_SQLITE_PRODUCTION=1
# DB_POOL_MIN_SIZE=2
# DB_POOL_MAX_SIZE=20
# DATABASE_READ_REPLICA_URL=
# DB_READ_POOL_MIN_SIZE=2
# DB_READ_POOL_MAX_SIZE=16
# BAUPASS_DR_MAX_BACKUP_AGE_HOURS=48
# BAUPASS_DR_REQUIRE_REPLICA=0
# BAUPASS_ARCHIVE_ACCESS_LOGS_ON_BOOT=0
# BAUPASS_ACCESS_LOG_RETENTION_DAYS=365
# Waitress (Railway default) does not support WebSocket upgrades — leave disabled.
# BAUPASS_WEBSOCKET_ENABLED=0
# BAUPASS_WEBSOCKET_REQUIRE_SESSION=1
# BAUPASS_ZERO_TRUST_DEVICE_BINDING=0
# BAUPASS_FIELD_ENCRYPTION_KEY=
# BAUPASS_PG_DR_SNAPSHOT_ON_BOOT=0
# BAUPASS_SAP_BASE_URL=
# BAUPASS_ORACLE_BASE_URL=
# BAUPASS_SCHEDULE_ACCESS_ARCHIVE=0
# BAUPASS_ZERO_TRUST_IP_ALLOWLIST=
# BAUPASS_ENFORCE_DATA_RESIDENCY=0

# ── Observability (optional) ─────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# BAUPASS_OTEL=0
# BAUPASS_LOG_FORWARD_URL=
# BAUPASS_LOG_FORWARD_TOKEN=

# ── Global cloud / edge (optional) ────────────────────────────────────────
# BAUPASS_DEFAULT_TIMEZONE=UTC
# BAUPASS_REGION=eu-west
# BAUPASS_REGION_STRATEGY=single
# BAUPASS_ACTIVE_REGIONS=eu-west,eu-central
# BAUPASS_CDN_CACHE_SECONDS=86400
# BAUPASS_PWA_SHELL_CACHE_SECONDS=300
# BAUPASS_REQUIRE_REDIS=0
# BAUPASS_PLATFORM_ENABLED=1

# ── Platform (optional) ───────────────────────────────────────────────────
# OPENAI_API_KEY=
# BAUPASS_AI_MODEL=gpt-4o-mini
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PROFESSIONAL=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# STRIPE_PRICE_STARTER_ANNUAL=price_...
# STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...
# STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...
# BAUPASS_STRIPE_TRIAL_DAYS=14
# BAUPASS_ZERO_TRUST=0
# BAUPASS_SEED_DEMO_ENTERPRISE=1
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# ── Worker Hybrid App (Flutter) — primary push channel ───────────────────────
# Option A (legacy): Firebase Console → Cloud Messaging → Server key
FCM_SERVER_KEY=
# Option B (recommended): FCM HTTP v1 service account JSON (one line or base64)
# FCM_PROJECT_ID=baupass-worker
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FCM_SERVICE_ACCOUNT_B64=
# FCM_V1_ONLY=1
# Enterprise: demo seed disabled on Railway unless explicitly enabled
# BAUPASS_ALLOW_DEMO=0
# BAUPASS_CONTACT_EMAIL=ops@your-company.de
# BAUPASS_OPS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# BAUPASS_OPS_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# Platform Guardian (Phase A): polls health every 60s, alerts on degraded/down.
# BAUPASS_GUARDIAN_ENABLED=1
# BAUPASS_GUARDIAN_INTERVAL_SECONDS=60
# BAUPASS_GUARDIAN_ALERT_COOLDOWN_SECONDS=900
# BAUPASS_GUARDIAN_NOTIFY_RECOVERY=1
# BAUPASS_GUARDIAN_WEBHOOK_URL=
# BAUPASS_GUARDIAN_TEAMS_WEBHOOK_URL=
# BAUPASS_GUARDIAN_WEBHOOK_URLS=
# Phase B — safe auto-remediation (sessions, retries, stale alerts)
# BAUPASS_GUARDIAN_REMEDIATION=1
# BAUPASS_GUARDIAN_REMEDIATION_COOLDOWN_SECONDS=300
# Phase C — login spike detection and security alerts
# BAUPASS_GUARDIAN_SECURITY=1
# BAUPASS_GUARDIAN_SECURITY_REMEDIATION=1
# BAUPASS_GUARDIAN_LOGIN_SPIKE_THRESHOLD=15
# BAUPASS_GUARDIAN_LOGIN_DAILY_THRESHOLD=50
# BAUPASS_GUARDIAN_SECURITY_ALERT_COOLDOWN_SECONDS=600
# BAUPASS_GUARDIAN_IP_BAN_THRESHOLD=8
# BAUPASS_GUARDIAN_IP_BAN_HOURS=2
# KI (required for BauPass AI assistant responses):
# OPENAI_API_KEY=sk-...
# GitHub secret FIREBASE_GOOGLE_SERVICES_JSON for mobile-release workflow
# Go-live validation: python backend/ops/validate_enterprise_env.py --base-url $PUBLIC_BASE_URL
# Docs: docs/enterprise-go-live-AR.md
# After GitHub Actions "Build worker APK" → Artifacts → host APK and set:
# BAUPASS_WORKER_APK_URL=https://your-cdn.example/baupass-worker.apk
# Daily cron (with BAUPASS_DAILY_JOBS_MODE=rq) sends FCM for documents expiring within 14 days.

# ── Kameras / RTSP-Bridge (Baustelle — ohne Code-Änderung) ───────────────────
# Geheimer Token für lokalen Agent auf der Baustelle (scripts/rtsp_camera_agent.py)
BAUPASS_RTSP_BRIDGE_TOKEN=change-me-long-random-rtsp-token
# Offline-Prüfung alle N Sekunden (Hintergrund-Thread, kein Worker nötig)
BAUPASS_CAMERA_HEALTH_SECONDS=120
# Kamera gilt als online wenn Heartbeat jünger als N Sekunden
BAUPASS_CAMERA_ONLINE_THRESHOLD_SECONDS=180
# Nachtbericht (PDF per E-Mail) im täglichen Job
BAUPASS_CAMERA_NIGHTLY_DIGEST=1
BAUPASS_CAMERA_DIGEST_HOURS=12
# Optional: Azure Face für Gesichtsabgleich auf Snapshots
# BAUPASS_AZURE_FACE_ENDPOINT=https://YOUR.cognitiveservices.azure.com
# BAUPASS_AZURE_FACE_KEY=
# BAUPASS_AZURE_FACE_MIN_CONFIDENCE=0.5
# Docs: docs/camera-rtsp-bridge-DE.md | Handover: docs/HANDOVER-PLATFORM-AR.md

# Legacy Web Push (browser PWA only — not used by Flutter hybrid app)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:admin@example.com

# Signotec signature pad — STPadServerLib.js on server (see vendor/signotec/README.md)
# Prefer: copy file to vendor/signotec/ via  npm run vendor:signotec  or  .\scripts\install-signotec-lib.ps1
# Fallback for tiny builds only (file usually too large for env var):
# BAUPASS_SIGNOTEC_LIB_BASE64=
