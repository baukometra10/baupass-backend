# Railway service variables (copy into Railway → Variables)

PUBLIC_BASE_URL=https://your-service.up.railway.app
# Pflicht für dauerhafte Daten (Mitarbeiter, Karten, Anträge) – Volume muss auf /data gemountet sein
BAUPASS_DB_PATH=/data/baupass.db
# Automatisches Backup beim Start (nur wenn persistent + Mitarbeiter vorhanden)
BAUPASS_BACKUP_ON_BOOT=1
BAUPASS_SECRET_KEY=change-me-long-random
BAUPASS_AUDIT_SIGNING_KEY=change-me-another-long-random

# SMTP (Brevo / Gmail)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=noreply@your-domain.de
SMTP_SENDER_NAME=BauPass

# Security
BAUPASS_ENABLE_HSTS=1
# Erst auf 1 setzen, wenn Superadmin E-Mail + OTP getestet wurde
BAUPASS_REQUIRE_SUPERADMIN_2FA=0
BAUPASS_IMMUTABLE_AUDIT=1
BAUPASS_LOGIN_RATE_MAX=120
BAUPASS_BACKUP_RETENTION_DAYS=30

# ── Redis (strongly recommended for production) ─────────────────────────────
# Railway: add Redis service → Reference REDIS_URL on API + Worker services
REDIS_URL=redis://default:password@redis.railway.internal:6379
BAUPASS_DAILY_JOBS_MODE=rq
BAUPASS_INVOICE_RETRY_MODE=rq
BAUPASS_DUNNING_MODE=rq
BAUPASS_WORKER_SESSION_CLEANUP_MODE=rq
# Second Railway service start command: python -m backend.app.tasks.worker

# ── PostgreSQL (optional — later phase; keep SQLite+/data for now) ─────────
# DATABASE_URL=postgresql://user:pass@host:5432/railway
# BAUPASS_ALLOW_SQLITE_PRODUCTION=1
# DATABASE_READ_REPLICA_URL=

# ── Observability (optional) ─────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# BAUPASS_OTEL=0
# BAUPASS_LOG_FORWARD_URL=

# ── Platform (optional) ───────────────────────────────────────────────────
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# BAUPASS_ZERO_TRUST=0

# Web Push (worker PWA)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
