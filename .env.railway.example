# Railway service variables (copy into Railway → Variables)

PUBLIC_BASE_URL=https://your-service.up.railway.app
# Login funktioniert nur mit vollständiger DB. Schnellstart mit SQLite auf Volume:
BAUPASS_PG_RUNTIME=0
# Pflicht für dauerhafte Daten (Mitarbeiter, Karten, Anträge) – Volume muss auf /data gemountet sein
BAUPASS_DB_PATH=/data/baupass.db
# Automatisches Backup beim Start (nur wenn persistent + Mitarbeiter vorhanden)
BAUPASS_BACKUP_ON_BOOT=1
BAUPASS_SECRET_KEY=change-me-long-random
BAUPASS_AUDIT_SIGNING_KEY=change-me-another-long-random

# SMTP (Brevo / Gmail)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=noreply@your-domain.de
SMTP_SENDER_NAME=BauPass

# Security
BAUPASS_ENABLE_HSTS=1
# Erst auf 1 setzen, wenn Superadmin E-Mail + OTP getestet wurde
BAUPASS_REQUIRE_SUPERADMIN_2FA=0
BAUPASS_IMMUTABLE_AUDIT=1
BAUPASS_LOGIN_RATE_MAX=120
BAUPASS_LOGIN_MAX_ATTEMPTS=12
BAUPASS_LOGIN_LOCK_MINUTES=10
# KI-Assistent (Enterprise-Tarif) — WICHTIG: Key und Modell getrennt!
# OPENAI_API_KEY = sk-proj-...  (nur hier, niemals als Modellname)
OPENAI_API_KEY=
# Optional Modell (Standard: gpt-4o-mini). NICHT den API-Key hier eintragen!
# BAUPASS_AI_MODEL=gpt-4o-mini
# Optional Azure OpenAI statt OpenAI:
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# Tool-Calling Agenten (11 Live-DB-Tools, 5 Spezial-Agenten)
BAUPASS_AI_TOOLS=1
# BAUPASS_AI_MAX_TOOL_ROUNDS=6
# Slack/Teams Tagesbriefing (optional)
# BAUPASS_AI_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# BAUPASS_AI_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# BAUPASS_AI_WEBHOOK_URL=
# Worker Voice (Whisper): OPENAI_API_KEY oben
# Tagesbriefing Cron (Enterprise, Slack/Teams oder E-Mail)
# BAUPASS_AI_BRIEFING_CRON=1
# BAUPASS_AI_BRIEFING_HOUR=7
# BAUPASS_AI_BRIEFING_TZ=Europe/Berlin
# BAUPASS_AI_BRIEFING_LANG=de
# BAUPASS_AI_BRIEFING_EMAIL=ops@firma.de
BAUPASS_BACKUP_RETENTION_DAYS=30

# ── Redis (strongly recommended for global production) ───────────────────────
# Railway: New → Database → Redis → Reference REDIS_URL on API + Worker
REDIS_URL=redis://default:password@redis.railway.internal:6379
# Second service start command: python -m backend.app.tasks.worker
BAUPASS_DAILY_JOBS_MODE=rq
BAUPASS_INVOICE_RETRY_MODE=rq
BAUPASS_DUNNING_MODE=rq
BAUPASS_WORKER_SESSION_CLEANUP_MODE=rq
# Second Railway service start command: python -m backend.app.tasks.worker

# Worker app join page (join.html) — set after APK / TestFlight are hosted
# BAUPASS_WORKER_APK_URL=https://your-cdn.example/app-release.apk
# BAUPASS_TESTFLIGHT_URL=https://testflight.apple.com/join/XXXXXXXX
# BAUPASS_PLAY_STORE_URL=
# BAUPASS_APP_STORE_URL=

# ── PostgreSQL (phase 2 — ONLY after sqlite_to_postgres.py + full schema) ─
# Do NOT set BAUPASS_PG_RUNTIME=1 until migration completed or the app may fail boot jobs.
# For Railway with /data volume, prefer SQLite (default):
#   BAUPASS_DB_PATH=/data/baupass.db
# DATABASE_URL=postgresql://user:pass@host:5432/railway
# BAUPASS_PG_RUNTIME=1
# BAUPASS_PG_REQUIRED=0
# BAUPASS_PG_AUTO_BOOTSTRAP=1
# BAUPASS_PG_BOOTSTRAP_SQLITE_PATH=/data/baupass.db
# BAUPASS_ALLOW_SQLITE_PRODUCTION=1
# DB_POOL_MIN_SIZE=2
# DB_POOL_MAX_SIZE=20
# DATABASE_READ_REPLICA_URL=
# DB_READ_POOL_MIN_SIZE=2
# DB_READ_POOL_MAX_SIZE=16
# BAUPASS_DR_MAX_BACKUP_AGE_HOURS=48
# BAUPASS_DR_REQUIRE_REPLICA=0
# BAUPASS_ARCHIVE_ACCESS_LOGS_ON_BOOT=0
# BAUPASS_ACCESS_LOG_RETENTION_DAYS=365
# BAUPASS_WEBSOCKET_REQUIRE_SESSION=1
# BAUPASS_ZERO_TRUST_DEVICE_BINDING=0
# BAUPASS_FIELD_ENCRYPTION_KEY=
# BAUPASS_PG_DR_SNAPSHOT_ON_BOOT=0
# BAUPASS_SAP_BASE_URL=
# BAUPASS_ORACLE_BASE_URL=
# BAUPASS_SCHEDULE_ACCESS_ARCHIVE=0
# BAUPASS_ZERO_TRUST_IP_ALLOWLIST=
# BAUPASS_ENFORCE_DATA_RESIDENCY=0

# ── Observability (optional) ─────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# BAUPASS_OTEL=0
# BAUPASS_LOG_FORWARD_URL=
# BAUPASS_LOG_FORWARD_TOKEN=

# ── Global cloud / edge (optional) ────────────────────────────────────────
# BAUPASS_DEFAULT_TIMEZONE=UTC
# BAUPASS_REGION=eu-west
# BAUPASS_REGION_STRATEGY=single
# BAUPASS_ACTIVE_REGIONS=eu-west,eu-central
# BAUPASS_CDN_CACHE_SECONDS=86400
# BAUPASS_PWA_SHELL_CACHE_SECONDS=300
# BAUPASS_REQUIRE_REDIS=0
# BAUPASS_PLATFORM_ENABLED=1

# ── Platform (optional) ───────────────────────────────────────────────────
# OPENAI_API_KEY=
# BAUPASS_AI_MODEL=gpt-4o-mini
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# BAUPASS_ZERO_TRUST=0
# BAUPASS_SEED_DEMO_ENTERPRISE=1
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# ── Worker Hybrid App (Flutter) — primary push channel ───────────────────────
# Firebase Console → Project settings → Cloud Messaging → Server key (legacy)
FCM_SERVER_KEY=
# After GitHub Actions "Build worker APK" → Artifacts → host APK and set:
# BAUPASS_WORKER_APK_URL=https://your-cdn.example/baupass-worker.apk
# Daily cron (with BAUPASS_DAILY_JOBS_MODE=rq) sends FCM for documents expiring within 14 days.

# Legacy Web Push (browser PWA only — not used by Flutter hybrid app)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:admin@example.com
