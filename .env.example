# BauPass – local / production environment (copy to .env or backend/.env.local)

# Public URL used for wallet passes and emailed links
PUBLIC_BASE_URL=http://127.0.0.1:8080

# Worker app join page (join.html) — internal distribution
# BAUPASS_WORKER_APK_URL=https://github.com/org/repo/actions/artifacts/...
# BAUPASS_TESTFLIGHT_URL=https://testflight.apple.com/join/XXXXXXXX
# Mobile worker session hardening (Flutter hybrid app)
# BAUPASS_WORKER_DEVICE_BINDING=1
# BAUPASS_WORKER_JWT=1
# BAUPASS_WORKER_JWT_SECRET=change-me-worker-jwt-secret
# BAUPASS_PLAY_STORE_URL=
# BAUPASS_APP_STORE_URL=

# SQLite database (default: backend/baupass.db)
# BAUPASS_DB_PATH=backend/baupass.db

# Production security (see .env.railway.example)
# BAUPASS_ENABLE_HSTS=1
# BAUPASS_REQUIRE_SUPERADMIN_2FA=1
# BAUPASS_IMMUTABLE_AUDIT=1
# BAUPASS_AUDIT_SIGNING_KEY=change-me-for-production
# BAUPASS_BACKUP_RETENTION_DAYS=30

# Redis (rate limiting + RQ background jobs)
REDIS_URL=redis://localhost:6379/0

# Platform layer (enterprise APIs — disable if startup issues: BAUPASS_PLATFORM_ENABLED=0)
# BAUPASS_PLATFORM_ENABLED=1

# Global cloud (Railway / any region)
# BAUPASS_DEFAULT_TIMEZONE=UTC
# BAUPASS_REGION=eu-west
# BAUPASS_CDN_CACHE_SECONDS=86400
# BAUPASS_PWA_SHELL_CACHE_SECONDS=300
# BAUPASS_REQUIRE_REDIS=0

# SQLite tuning (WAL + cache; defaults are production-safe)
# BAUPASS_SQLITE_CACHE_KB=64000
# BAUPASS_SQLITE_MMAP_MB=256
# BAUPASS_SQLITE_BUSY_TIMEOUT_MS=60000

# Observability (optional)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Public Developer API / AI (optional) — key and model are separate variables
# OPENAI_API_KEY=sk-...
# BAUPASS_AI_MODEL=gpt-4o-mini

# Object storage (optional — default local)
# UPLOAD_BACKEND=local
# UPLOAD_BACKEND=s3
# S3_BUCKET=
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# PostgreSQL (production target)
# DATABASE_URL=postgresql://user:pass@host:5432/baupass

# Background job modes: auto | rq | thread
BAUPASS_DAILY_JOBS_MODE=auto
BAUPASS_WORKER_SESSION_CLEANUP_MODE=auto
BAUPASS_INVOICE_RETRY_MODE=auto
BAUPASS_DUNNING_MODE=auto

# Faster local dev imports
# BAUPASS_ENABLE_BACKGROUND_JOBS=0
# BAUPASS_ENABLE_IMAP_POLLER=0

# Web Push (worker PWA)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# Wallet signing – see backend/.env.wallet.example
# APPLE_TEAM_ID=
# GOOGLE_ISSUER_ID=

# Production security (Railway: set in service variables)
# PUBLIC_BASE_URL=https://baupass-production.up.railway.app
# BAUPASS_ENABLE_HSTS=1
# BAUPASS_REQUIRE_SUPERADMIN_2FA=1
# BAUPASS_IMMUTABLE_AUDIT=1
# BAUPASS_AUDIT_SIGNING_KEY=<long-random-secret>
# BAUPASS_BACKUP_RETENTION_DAYS=30
# BAUPASS_LOGIN_RATE_MAX=120
# BAUPASS_LOGIN_MAX_ATTEMPTS=12
# BAUPASS_LOGIN_LOCK_MINUTES=10
