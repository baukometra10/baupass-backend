# BauPass – local / production environment (copy to .env or backend/.env.local)

# Public URL used for wallet passes and emailed links
PUBLIC_BASE_URL=http://127.0.0.1:8080

# SQLite database (default: backend/baupass.db)
# BAUPASS_DB_PATH=backend/baupass.db

# Redis (rate limiting + RQ background jobs)
REDIS_URL=redis://localhost:6379/0

# Background job modes: auto | rq | thread
BAUPASS_DAILY_JOBS_MODE=auto
BAUPASS_WORKER_SESSION_CLEANUP_MODE=auto
BAUPASS_INVOICE_RETRY_MODE=auto
BAUPASS_DUNNING_MODE=auto

# Faster local dev imports
# BAUPASS_ENABLE_BACKGROUND_JOBS=0
# BAUPASS_ENABLE_IMAP_POLLER=0

# Web Push (worker PWA)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# Wallet signing – see backend/.env.wallet.example
# APPLE_TEAM_ID=
# GOOGLE_ISSUER_ID=
