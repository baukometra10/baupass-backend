# WorkPass – local / production environment (copy to .env or backend/.env.local)

# Public URL used for wallet passes and emailed links
PUBLIC_BASE_URL=http://127.0.0.1:8080

# Worker app join page (join.html) — internal distribution
# SUPPIX_WORKER_APK_URL=https://github.com/org/repo/releases/download/v1.0.0/app-release.apk
# CI only (GitHub Actions secret): SUPPIX_SMOKE_TOKEN=<jwt from scripts/get-smoke-token.ps1>
# SUPPIX_TESTFLIGHT_URL=https://testflight.apple.com/join/XXXXXXXX
# Mobile worker session hardening (Flutter hybrid app)
# SUPPIX_WORKER_DEVICE_BINDING=1
# SUPPIX_WORKER_JWT=1
# SUPPIX_WORKER_JWT_SECRET=change-me-worker-jwt-secret
# SUPPIX_PLAY_STORE_URL=
# SUPPIX_APP_STORE_URL=

# SQLite database (default: backend/baupass.db)
# SUPPIX_DB_PATH=backend/baupass.db

# Production security (see .env.railway.example)
# SUPPIX_ENABLE_HSTS=1
# SUPPIX_REQUIRE_SUPERADMIN_2FA=1
# SUPPIX_IMMUTABLE_AUDIT=1
# SUPPIX_AUDIT_SIGNING_KEY=change-me-for-production
# SUPPIX_BACKUP_RETENTION_DAYS=30

# Redis (rate limiting + RQ background jobs)
REDIS_URL=redis://localhost:6379/0

# Platform layer (enterprise APIs — disable if startup issues: SUPPIX_PLATFORM_ENABLED=0)
# SUPPIX_PLATFORM_ENABLED=1

# Global cloud (Railway / any region)
# SUPPIX_DEFAULT_TIMEZONE=UTC
# SUPPIX_REGION=eu-west
# SUPPIX_CDN_CACHE_SECONDS=86400
# SUPPIX_PWA_SHELL_CACHE_SECONDS=300
# SUPPIX_REQUIRE_REDIS=0

# SQLite tuning (WAL + cache; defaults are production-safe)
# SUPPIX_SQLITE_CACHE_KB=64000
# SUPPIX_SQLITE_MMAP_MB=256
# SUPPIX_SQLITE_BUSY_TIMEOUT_MS=60000

# Observability (optional)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Public Developer API / AI (optional) — key and model are separate variables
# OPENAI_API_KEY=sk-...
# SUPPIX_AI_MODEL=gpt-4o-mini

# Object storage (optional — default local)
# UPLOAD_BACKEND=local
# UPLOAD_BACKEND=s3
# S3_BUCKET=
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# PostgreSQL (production target)
# DATABASE_URL=postgresql://user:pass@host:5432/baupass

# Background job modes: auto | rq | thread
SUPPIX_DAILY_JOBS_MODE=auto
SUPPIX_WORKER_SESSION_CLEANUP_MODE=auto
SUPPIX_INVOICE_RETRY_MODE=auto
SUPPIX_DUNNING_MODE=auto

# Faster local dev imports
# SUPPIX_ENABLE_BACKGROUND_JOBS=0
# SUPPIX_ENABLE_IMAP_POLLER=0

# Web Push (worker PWA)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# Native push (Flutter FCM) — Firebase Console → Project settings → Cloud Messaging → Server key
# FCM_SERVER_KEY=

# Firmenkonferenz (LiveKit SFU) — docs/livekit-setup.md
# SUPPIX_LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
# SUPPIX_LIVEKIT_API_KEY=
# SUPPIX_LIVEKIT_API_SECRET=

# Wallet signing – see backend/.env.wallet.example
# APPLE_TEAM_ID=
# GOOGLE_ISSUER_ID=

# Production security (Railway: set in service variables)
# PUBLIC_BASE_URL=https://baupass-production.up.railway.app
# SUPPIX_ENABLE_HSTS=1
# SUPPIX_REQUIRE_SUPERADMIN_2FA=1
# SUPPIX_IMMUTABLE_AUDIT=1
# SUPPIX_AUDIT_SIGNING_KEY=<long-random-secret>
# SUPPIX_FIELD_ENCRYPTION_KEY=<long-random-secret>  # Chat at-rest (Fernet)
# BAUPASS_RTSP_BRIDGE_TOKEN=<long-random-token>     # Local camera agent
# SUPPIX_BACKUP_RETENTION_DAYS=30
# SUPPIX_LOGIN_RATE_MAX=120
# SUPPIX_LOGIN_MAX_ATTEMPTS=12
# SUPPIX_LOGIN_LOCK_MINUTES=10
