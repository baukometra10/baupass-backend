# Copy this file to backend/.env.local and fill with real values.
# Never commit real keys/certificates.
# Railway: prefer *_BASE64 / GOOGLE_SERVICE_ACCOUNT_JSON — see docs/railway-wallet-setup.md

# --- Apple Wallet (PassKit) ---
APPLE_TEAM_ID=
APPLE_PASS_TYPE_ID=
# Local file OR Railway base64 (one is enough):
APPLE_CERT_PATH=backend/wallet/apple-passkit.p12
# APPLE_CERT_BASE64=
APPLE_CERT_PASSWORD=
APPLE_INTERMEDIATE_CERT_PATH=backend/wallet/apple-intermediate.cer
# APPLE_INTERMEDIATE_CERT_BASE64=

# --- Google Wallet ---
GOOGLE_ISSUER_ID=
GOOGLE_PROJECT_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=backend/wallet/google-service-account.json
# Railway preferred:
# GOOGLE_SERVICE_ACCOUNT_JSON={...full JSON...}

# Optional: override default class id (<issuer>.baukometra_worker)
GOOGLE_WALLET_CLASS_ID=
