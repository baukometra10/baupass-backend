# ═══════════════════════════════════════════════════════════════════════════════
# WorkPass — Production Environment (Railway / Hetzner / Windows Service)
# Platform: WorkPass | Company: Suppix AI
#
# HOW TO USE:
#   1. Copy this file → Railway → Variables (paste each line)
#   2. Replace all REPLACE_* placeholders with real secrets
#   3. Validate: python backend/ops/validate_enterprise_env.py --base-url $PUBLIC_BASE_URL
#
# Canonical prefix: SUPPIX_*  (BAUPASS_* legacy mirror still works at startup)
# ═══════════════════════════════════════════════════════════════════════════════

# ── 1) REQUIRED — Core ──────────────────────────────────────────────────────
PUBLIC_BASE_URL=https://baupass-production.up.railway.app
SUPPIX_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX
SUPPIX_AUDIT_SIGNING_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX
SUPPIX_IMMUTABLE_AUDIT=1
SUPPIX_ENABLE_HSTS=1
SUPPIX_ALLOW_DEMO=0

# ── 2) REQUIRED — Database (SQLite on Volume — recommended for Railway) ───────
SUPPIX_PG_RUNTIME=0
SUPPIX_DB_PATH=/data/baupass.db
SUPPIX_SQLITE_JOURNAL_MODE=DELETE
SUPPIX_BACKUP_ON_BOOT=1
SUPPIX_BACKUP_RETENTION_DAYS=30

# ── 3) REQUIRED — SMTP (WorkPass outbound mail) ───────────────────────────────
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USERNAME=suppix-workpass-ai@outlook.de
SMTP_PASSWORD=REPLACE_WITH_MICROSOFT_APP_PASSWORD
SMTP_SENDER_EMAIL=suppix-workpass-ai@outlook.de
SMTP_SENDER_NAME=WorkPass
SUPPIX_CONTACT_EMAIL=suppix-workpass-ai@outlook.de
SUPPIX_FOUNDER_EMAIL=suppix-workpass-ai@outlook.de

# ── 4) REQUIRED — Worker Hybrid App (Flutter) ─────────────────────────────────
SUPPIX_WORKER_DEVICE_BINDING=1
SUPPIX_WORKER_JWT=1
SUPPIX_WORKER_JWT_SECRET=REPLACE_WITH_32_PLUS_CHAR_RANDOM
SUPPIX_TESTFLIGHT_URL=https://testflight.apple.com/join/REPLACE
SUPPIX_WORKER_APK_URL=https://your-cdn.example/app-release.apk

# ── 5) STRONGLY RECOMMENDED — Redis + background worker service ───────────────
REDIS_URL=${{Redis.REDIS_URL}}
SUPPIX_DAILY_JOBS_MODE=rq
SUPPIX_INVOICE_RETRY_MODE=rq
SUPPIX_DUNNING_MODE=rq
SUPPIX_WORKER_SESSION_CLEANUP_MODE=rq
# Second Railway service: python -m backend.app.tasks.worker

# ── 6) RECOMMENDED — Push (FCM for Flutter) ───────────────────────────────────
FCM_SERVER_KEY=
# FCM_PROJECT_ID=workpass-worker
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FCM_V1_ONLY=1

# ── 7) RECOMMENDED — Suppix AI assistant ──────────────────────────────────────
OPENAI_API_KEY=sk-proj-REPLACE
SUPPIX_AI_MODEL=gpt-4o-mini
SUPPIX_AI_TOOLS=1
SUPPIX_FOUNDER_NAME=Sherif Mohamed
SUPPIX_FOUNDER_TITLE=Gründer & Geschäftsführer
SUPPIX_FOUNDER_COMPANY=Suppix Technologie UG
SUPPIX_TTS_PROVIDER=openai

# ── 8) OPTIONAL — Stripe billing ──────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_REPLACE
# STRIPE_WEBHOOK_SECRET=whsec_REPLACE
# STRIPE_PRICE_STARTER=price_REPLACE
# STRIPE_PRICE_PROFESSIONAL=price_REPLACE
# STRIPE_PRICE_ENTERPRISE=price_REPLACE
# SUPPIX_STRIPE_TRIAL_DAYS=14

# ── 9) OPTIONAL — Security hardening ──────────────────────────────────────────
SUPPIX_REQUIRE_SUPERADMIN_2FA=0
SUPPIX_LOGIN_RATE_MAX=120
SUPPIX_LOGIN_MAX_ATTEMPTS=12
SUPPIX_LOGIN_LOCK_MINUTES=10
# At-rest Fernet for legacy non-E2E columns (optional; not a substitute for E2E)
# SUPPIX_FIELD_ENCRYPTION_KEY=
# End-to-end encryption policy (default: all on — do not disable in production)
BAUPASS_E2E_CHAT_REQUIRED=1
BAUPASS_E2E_ATTACHMENTS_REQUIRED=1
BAUPASS_E2E_SENSITIVE_REQUIRED=1
# SUPPIX_GATE_API_KEY=

# ── 10) OPTIONAL — Cameras / RTSP bridge ──────────────────────────────────────
SUPPIX_RTSP_BRIDGE_TOKEN=REPLACE_WITH_LONG_RANDOM_TOKEN
SUPPIX_CAMERA_HEALTH_SECONDS=120
SUPPIX_CAMERA_ONLINE_THRESHOLD_SECONDS=180
SUPPIX_CAMERA_NIGHTLY_DIGEST=1
SUPPIX_CAMERA_DIGEST_HOURS=12

# ── 11) OPTIONAL — Observability ──────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SUPPIX_GUARDIAN_ENABLED=1
# SUPPIX_GUARDIAN_WEBHOOK_URL=

# ── 12) OPTIONAL — Wallet (Apple / Google) — see backend/.env.wallet.example ──
# APPLE_TEAM_ID=
# GOOGLE_ISSUER_ID=

# ── 13) OPTIONAL — Web Push (browser PWA fallback only) ───────────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:admin@example.com

# ── 14) Local / self-hosted only (NOT for Railway) ────────────────────────────
# HOST=0.0.0.0
# PORT=8080
# WORKPASS_DESKTOP_URL=http://127.0.0.1:8080

# Full reference: .env.railway.example | backend/PRODUCTION_ENV_VARS.md
