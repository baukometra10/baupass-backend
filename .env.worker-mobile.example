# ═══════════════════════════════════════════════════════════════════════════════
# BauPass — متغيرات Railway لتطبيق الموظف Hybrid (Flutter)
# انسخ إلى Railway → Variables (خدمة API الرئيسية)
# تحقق بعد النشر: GET https://YOUR-DOMAIN/api/worker-app/mobile-setup
# ═══════════════════════════════════════════════════════════════════════════════

# ── 1) إلزامي — Backend + روابط ─────────────────────────────────────────────
PUBLIC_BASE_URL=https://baupass-production.up.railway.app
BAUPASS_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM
BAUPASS_AUDIT_SIGNING_KEY=REPLACE_WITH_64_CHAR_RANDOM
BAUPASS_IMMUTABLE_AUDIT=1
BAUPASS_ENABLE_HSTS=1
BAUPASS_ALLOW_DEMO=0

# ── 2) إلزامي — قاعدة البيانات (اختر SQLite أو PostgreSQL) ─────────────────

# أ) SQLite على Volume (الأبسط — Volume mount /data)
BAUPASS_PG_RUNTIME=0
BAUPASS_DB_PATH=/data/baupass.db
BAUPASS_BACKUP_ON_BOOT=1

# ب) PostgreSQL (بعد ترحيل كامل)
# BAUPASS_PG_RUNTIME=1
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# BAUPASS_PG_AUTO_BOOTSTRAP=1
# BAUPASS_PG_BOOTSTRAP_SQLITE_PATH=/data/baupass.db

# ── 3) إلزامي — تطبيق الموظف (جلسات + ربط جهاز) ─────────────────────────────
BAUPASS_WORKER_DEVICE_BINDING=1
BAUPASS_WORKER_JWT=1
BAUPASS_WORKER_JWT_SECRET=REPLACE_WITH_32_PLUS_CHAR_RANDOM

# ── 4) إلزامي لـ iPhone — TestFlight (توزيع داخلي) ───────────────────────────
# من App Store Connect → TestFlight → رابط الدعوة العام
BAUPASS_TESTFLIGHT_URL=https://testflight.apple.com/join/XXXXXXXX

# ── 5) موصى به — Android APK (رابط عام بعد CI أو Release) ───────────────────
# GitHub Actions → Build worker APK → ارفع الملف → ضع الرابط هنا
BAUPASS_WORKER_APK_URL=https://YOUR-CDN-OR-GITHUB-RELEASE/app-release.apk

# ── 6) موصى به — Redis + Worker service ─────────────────────────────────────
REDIS_URL=${{Redis.REDIS_URL}}
BAUPASS_WORKER_SESSION_CLEANUP_MODE=rq
# خدمة Railway ثانية: python -m backend.app.tasks.worker

# ── 7) اختياري — Push (لا يمنع Login / NFC / QR) ───────────────────────────
# FCM_PROJECT_ID=baupass-worker
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# أو مؤقتاً: FCM_SERVER_KEY=...

# ── 8) اختياري — متاجر عامة (المرحلة 2 فقط) ─────────────────────────────────
# BAUPASS_PLAY_STORE_URL=
# BAUPASS_APP_STORE_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# التطبيق على iPhone لا يقرأ هذه المتغيرات مباشرة.
# عند بناء IPA على Mac:
#   flutter build ipa --release \
#     --dart-define=BAUPASS_API_URL=https://baupass-production.up.railway.app
# ═══════════════════════════════════════════════════════════════════════════════
