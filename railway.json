{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"],
      "phases": {
        "install": {
          "cmds": [
            "python3 -m venv .venv",
            "PIP_BREAK_SYSTEM_PACKAGES=1 .venv/bin/pip install --no-cache-dir -r backend/requirements.txt"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": ".venv/bin/python backend/run_prod.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "volumes": [
    {
      "mountPath": "/data"
    }
  ]
}